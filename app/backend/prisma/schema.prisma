// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider   = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider = "postgresql"
}

// -----------------------------------------------------------------------------
// FACILITY PROFILE
// -----------------------------------------------------------------------------

model Facility {
  id                String            @id @default(uuid()) @db.Uuid
  name              String            @unique
  type              String            // e.g. 'clinic', 'nursing_home', 'hospital'
  address           String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  labs              FacilityLab[]
  imaging           FacilityImaging[]
  drugs             FacilityDrug[]
  services          FacilityService[]
  doctors           Doctor[]
  patients          Patient[]
  visits            Visit[]
  auditLogs         AuditLog[]

  @@map("facility")
}

model FacilityLab {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  code              String
  name              String
  specimen          String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  investigationOrders InvestigationOrder[]

  @@unique([facilityId, code])
  @@map("facility_lab")
}

model FacilityImaging {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  code              String
  name              String
  modality          String?           // e.g. X-ray, USG, CT, MRI
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  investigationOrders InvestigationOrder[]

  @@unique([facilityId, code])
  @@map("facility_imaging")
}

model FacilityDrug {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  code              String
  name              String
  form              String?           // tablet, syrup, injection, etc.
  strength          String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)
  prescriptions     Prescription[]

  @@unique([facilityId, code])
  @@map("facility_drug")
}

model FacilityService {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  code              String
  name              String
  category          String?           // e.g. procedure, referral_specialty, bed_type
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id], onDelete: Cascade)

  @@unique([facilityId, code])
  @@map("facility_service")
}

// -----------------------------------------------------------------------------
// STAFF & DOCTOR
// -----------------------------------------------------------------------------

model Doctor {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  externalId        String?           @map("external_id")
  fullName          String            @map("full_name")
  qualification     String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id])
  visits            Visit[]
  finalizedFindings ClinicalFinding[] @relation("FinalizedBy")
  createdFindings   ClinicalFinding[] @relation("CreatedBy")
  finalizedDiagnoses Diagnosis[]       @relation("FinalizedBy")
  createdDiagnoses   Diagnosis[]       @relation("CreatedBy")
  finalizedPrescriptions Prescription[] @relation("FinalizedBy")
  createdPrescriptions   Prescription[] @relation("CreatedBy")
  finalizedOrders     InvestigationOrder[] @relation("FinalizedBy")
  createdOrders       InvestigationOrder[] @relation("CreatedBy")
  finalizedAdvice     Advice[]          @relation("FinalizedBy")
  createdAdvice       Advice[]          @relation("CreatedBy")
  finalizedFollowUps  FollowUp[]        @relation("FinalizedBy")
  createdFollowUps    FollowUp[]        @relation("CreatedBy")
  auditLogs         AuditLog[]

  @@unique([facilityId, externalId])
  @@map("doctor")
}

// -----------------------------------------------------------------------------
// PATIENT
// -----------------------------------------------------------------------------

model Patient {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  externalId        String?           @map("external_id")
  fullName          String            @map("full_name")
  dateOfBirth       DateTime?         @map("date_of_birth") @db.Date
  sex               String?
  contact           String?
  address           String?
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id])
  visits            Visit[]
  diagnoses         Diagnosis[]
  auditLogs         AuditLog[]

  @@unique([facilityId, externalId])
  @@map("patient")
}

// -----------------------------------------------------------------------------
// VISIT
// -----------------------------------------------------------------------------

model Visit {
  id                String            @id @default(uuid()) @db.Uuid
  facilityId        String            @map("facility_id") @db.Uuid
  patientId         String            @map("patient_id") @db.Uuid
  doctorId          String            @map("doctor_id") @db.Uuid
  visitNumber       Int               @map("visit_number")
  visitDate         DateTime          @map("visit_date") @db.Date
  visitType         String?           @map("visit_type") // e.g. new, follow_up, referral_in
  chiefComplaint    String?           @map("chief_complaint")
  status            String            @default("open")   // open, closed
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz
  
  facility          Facility          @relation(fields: [facilityId], references: [id])
  patient           Patient           @relation(fields: [patientId], references: [id])
  doctor            Doctor            @relation(fields: [doctorId], references: [id])
  
  findings          ClinicalFinding[]
  diagnoses         Diagnosis[]
  prescriptions     Prescription[]
  orders            InvestigationOrder[]
  advice            Advice[]
  followUps         FollowUp[]
  auditLogs         AuditLog[]

  @@unique([patientId, visitNumber])
  @@map("visit")
}

// -----------------------------------------------------------------------------
// CLINICAL DATA
// -----------------------------------------------------------------------------

model ClinicalFinding {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String            @map("visit_id") @db.Uuid
  findingType       String            @map("finding_type") // vitals, examination, history
  nameOrCode        String?           @map("name_or_code")
  valueText         String?           @map("value_text")
  valueNumeric      Decimal?          @map("value_numeric") @db.Decimal
  valueUnit         String?           @map("value_unit")
  freeText          String?           @map("free_text")
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("clinical_finding")
}

model Diagnosis {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String?           @map("visit_id") @db.Uuid
  patientId         String            @map("patient_id") @db.Uuid
  code              String?
  term              String
  type              String            // visit_diagnosis, chronic_problem
  isPrimary         Boolean           @default(false) @map("is_primary")
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  resolvedAt        DateTime?         @map("resolved_at") @db.Timestamptz
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit?            @relation(fields: [visitId], references: [id], onDelete: Cascade)
  patient           Patient           @relation(fields: [patientId], references: [id], onDelete: Cascade)
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("diagnosis")
}

model Prescription {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String            @map("visit_id") @db.Uuid
  facilityDrugId    String?           @map("facility_drug_id") @db.Uuid
  drugName          String            @map("drug_name")
  form              String?
  strength          String?
  dose              String
  route             String?
  frequency         String?
  duration          String?
  instructions      String?
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  facilityDrug      FacilityDrug?     @relation(fields: [facilityDrugId], references: [id])
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("prescription")
}

model InvestigationOrder {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String            @map("visit_id") @db.Uuid
  orderType         String            @map("order_type") // lab, imaging
  facilityLabId     String?           @map("facility_lab_id") @db.Uuid
  facilityImagingId String?           @map("facility_imaging_id") @db.Uuid
  code              String
  name              String
  clinicalNotes     String?           @map("clinical_notes")
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  facilityLab       FacilityLab?      @relation(fields: [facilityLabId], references: [id])
  facilityImaging   FacilityImaging?  @relation(fields: [facilityImagingId], references: [id])
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("investigation_order")
}

model Advice {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String            @map("visit_id") @db.Uuid
  adviceType        String            @map("advice_type") // general_advice, diet, lifestyle, referral_advice
  content           String
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("advice")
}

model FollowUp {
  id                String            @id @default(uuid()) @db.Uuid
  visitId           String            @map("visit_id") @db.Uuid
  followUpDate      DateTime?         @map("follow_up_date") @db.Date
  followUpNotes     String?           @map("follow_up_notes")
  isFinal           Boolean           @default(false) @map("is_final")
  finalizedAt       DateTime?         @map("finalized_at") @db.Timestamptz
  finalizedById     String?           @map("finalized_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  createdById       String?           @map("created_by_id") @db.Uuid
  
  visit             Visit             @relation(fields: [visitId], references: [id], onDelete: Cascade)
  finalizedBy       Doctor?           @relation("FinalizedBy", fields: [finalizedById], references: [id])
  createdBy         Doctor?           @relation("CreatedBy", fields: [createdById], references: [id])

  @@map("follow_up")
}

model AuditLog {
  id                String            @id @default(uuid()) @db.Uuid
  occurredAt        DateTime          @default(now()) @map("occurred_at") @db.Timestamptz
  facilityId        String?           @map("facility_id") @db.Uuid
  visitId           String?           @map("visit_id") @db.Uuid
  patientId         String?           @map("patient_id") @db.Uuid
  doctorId          String?           @map("doctor_id") @db.Uuid
  actionType        String            @map("action_type") // e.g. suggestion_shown, edit, finalize, view
  entityType        String            @map("entity_type") // e.g. diagnosis, prescription, investigation_order
  entityId          String?           @map("entity_id") @db.Uuid
  payload           Json?             // non-PHI summary
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  
  facility          Facility?         @relation(fields: [facilityId], references: [id])
  visit             Visit?            @relation(fields: [visitId], references: [id])
  patient           Patient?          @relation(fields: [patientId], references: [id])
  doctor            Doctor?           @relation(fields: [doctorId], references: [id])

  @@map("audit_log")
}
